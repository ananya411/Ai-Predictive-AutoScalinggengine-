# ─── Required ───────────────────────────────────────────────────
# A strong, random secret for signing JWTs (minimum 32 chars recommended)
JWT_SECRET=your_jwt_secret_here

# Bcrypt-hashed admin password (generate with: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)")
ADMIN_PASS_HASH=your_bcrypt_hash_here

# ─── Optional ───────────────────────────────────────────────────
# Admin username (default: admin)
# ADMIN_USER=admin

# Server port (default: 5000)
# PORT=5000

# Allowed CORS origins, comma-separated (default: http://localhost:5173)
# CORS_ORIGIN=http://localhost:5173

# Autoscaler poll interval in ms (default: 5000)
# POLL_INTERVAL_MS=5000

# Number of CPU data points to keep for ML models (default: 10)
# CPU_HISTORY_WINDOW=10

# Minimum data points before ML models start training (default: 6)
# MIN_TRAIN_SAMPLES=6

# Scaling thresholds
# SCALE_UP_THRESHOLD=70
# SCALE_DOWN_THRESHOLD=30
# MAX_INSTANCES=10
# MIN_INSTANCES=1
# COOLDOWN_MS=20000
# CONFIDENCE_THRESHOLD=0.6
